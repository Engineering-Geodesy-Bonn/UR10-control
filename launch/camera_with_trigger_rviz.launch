<?xml version="1.0"?>
<launch>
    <!-- Start the Basler camera node -->
    <include file="$(find pylon_camera)/launch/pylon_camera_node.launch">
        <arg name="camera_name" value="/pylon_camera_node" />
    </include>

    <!-- Start the newly created trigger node -->
    <node name="camera_trigger_node" pkg="pylon_camera" type="trigger_camera.py" output="screen" />

    <!-- Start RViz configured to display the camera trigger image -->
    <node name="$(anon rviz)" pkg="rviz" type="rviz" args="-d $(find ur_modern_driver)/config/camera_visualization.rviz" output="screen" />
</launch>
